{
  "name": "carbon-footprint-platform",
  "version": "1.0.0",
  "description": "Virtual Carbon Footprint Awareness Platform - Track and reduce your environmental impact",
  "main": "dist/src/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only backend/src/app.ts",
    "build": "tsc --project backend/tsconfig.json",
    "start": "node dist/src/app.js",
    "test": "jest --coverage",
    "test:unit": "jest --testPathPattern=unit --coverage",
    "test:integration": "jest --testPathPattern=integration",
    "test:e2e": "jest --testPathPattern=e2e",
    "test:coverage": "jest --coverage --coverageThreshold='{\"lines\":90,\"functions\":90,\"branches\":90,\"statements\":90}'",
    "test:accessibility": "jest --testPathPattern=accessibility",
    "audit:a11y": "node scripts/a11y-audit.js",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"backend/**/*.ts\" \"frontend/**/*.tsx\"",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js",
    "security:audit": "npm audit",
    "security:check": "snyk test",
    "docker:build": "docker build -t carbon-footprint:latest .",
    "docker:run": "docker-compose up",
    "deploy": "npm run build && npm run test && git push origin main"
  },
  "keywords": [
    "carbon",
    "footprint",
    "environment",
    "sustainability",
    "emissions",
    "tracking",
    "eco-friendly"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "@google-cloud/bigquery": "^7.1.0",
    "@google-cloud/storage": "^7.0.0",
    "axios": "^1.5.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "google-auth-library": "^9.0.0",
    "googleapis": "^118.0.0",
    "helmet": "^7.0.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.1",
    "redis": "^4.6.10",
    "sequelize": "^6.33.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.20",
    "@types/jest": "^29.5.7",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.8.0",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^6.7.5",
    "@typescript-eslint/parser": "^6.7.5",
    "eslint": "^8.51.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.3",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
